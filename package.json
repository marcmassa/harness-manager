{
  "name": "harness-manager-vscode",
  "displayName": "Harness Manager",
  "description": "Visual dashboard and whiteboard for managing Harness SDD projects.",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "type": "module",
  "activationEvents": [
    "onView:harness-manager.dashboard"
  ],
  "main": "./dist/extension.cjs",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "harness-manager",
          "title": "Harness Manager",
          "icon": "$(gear)"
        }
      ]
    },
    "views": {
      "harness-manager": [
        {
          "type": "webview",
          "id": "harness-manager.dashboard",
          "name": "Dashboard"
        }
      ]
    },
    "commands": [
      {
        "command": "harness-manager.openDashboard",
        "title": "Harness: Open Dashboard"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.19.11",
    "typescript": "^5.3.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@types/dagre": "^0.7.54",
    "@vscode/webview-ui-toolkit": "^1.2.2",
    "dagre": "^0.8.5",
    "gray-matter": "^4.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reactflow": "^11.11.4"
  }
}
