{
  "name": "harness-dashboard-vscode",
  "displayName": "Harness Dashboard",
  "description": "Visual whiteboard to map, trace and manage AI agent architectures (subagents, skills, relationships). Supports Harness SDD, Claude Code, Gemini CLI, Cursor, Copilot and more.",
  "version": "0.3.0",
  "publisher": "marcmassacapo",
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#12121e",
    "theme": "dark"
  },
  "keywords": [
    "ai agents",
    "agent architecture",
    "harness sdd",
    "whiteboard",
    "subagents",
    "claude code",
    "gemini",
    "cursor",
    "copilot",
    "visualization",
    "graph",
    "spec driven development"
  ],
  "categories": [
    "Visualization",
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/marcmassa/harness-manager"
  },
  "bugs": {
    "url": "https://github.com/marcmassa/harness-manager/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "type": "module",
  "activationEvents": [
    "onView:harness-dashboard.dashboard"
  ],
  "main": "./dist/extension.cjs",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "harness-dashboard",
          "title": "Harness Dashboard",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "harness-dashboard": [
        {
          "type": "webview",
          "id": "harness-dashboard.dashboard",
          "name": "Dashboard"
        }
      ]
    },
    "commands": [
      {
        "command": "harness-dashboard.openDashboard",
        "title": "Harness: Open Dashboard"
      }
    ],
    "configuration": {
      "title": "Harness Dashboard",
      "properties": {
        "harness-dashboard.adapters.claude-code.path": {
          "type": "string",
          "scope": "resource",
          "default": ".claude",
          "description": "Path to the Claude Code agent configuration directory (relative to workspace root)."
        },
        "harness-dashboard.adapters.cursor.path": {
          "type": "string",
          "scope": "resource",
          "default": ".cursor",
          "description": "Path to the Cursor agent configuration directory (relative to workspace root)."
        },
        "harness-dashboard.adapters.gemini-cli.path": {
          "type": "string",
          "scope": "resource",
          "default": ".gemini",
          "description": "Path to the Gemini CLI agent configuration directory (relative to workspace root)."
        },
        "harness-dashboard.adapters.copilot.path": {
          "type": "string",
          "scope": "resource",
          "default": ".github",
          "description": "Path to the GitHub Copilot instructions directory (relative to workspace root). The .vscode/prompts/ directory is unaffected by this setting."
        },
        "harness-dashboard.adapters.windsurf.path": {
          "type": "string",
          "scope": "resource",
          "default": ".windsurf",
          "description": "Path to the Windsurf rules directory (relative to workspace root)."
        },
        "harness-dashboard.adapters.kiro.path": {
          "type": "string",
          "scope": "resource",
          "default": ".kiro",
          "description": "Path to the Kiro agent configuration directory (relative to workspace root)."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:integration": "npm run build && node ./out/test/integration/runIntegrationTests.cjs",
    "package": "npm run build && vsce package --no-dependencies",
    "publish": "npm run build && vsce publish --no-dependencies",
    "vsce:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/vscode": "^1.85.0",
    "@vitest/coverage-v8": "^4.1.8",
    "@vscode/test-electron": "2.5.2",
    "@vscode/vsce": "^3.9.2",
    "canvas": "^3.2.3",
    "esbuild": "^0.28.1",
    "mocha": "^11.7.6",
    "typescript": "^5.3.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@types/dagre": "^0.7.54",
    "@vscode/webview-ui-toolkit": "^1.2.2",
    "dagre": "^0.8.5",
    "gray-matter": "^4.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reactflow": "^11.11.4"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.5"
  }
}
