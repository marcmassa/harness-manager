{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    ".agents/harness/CONVENTION.md"
  ],
  "skills": {
    "paths": [".agents/skills"]
  },
  "default_agent": "harness",
  "agent": {
    "harness": {
      "mode": "primary",
      "description": "Default orchestrator. Reads feature_list.json, routes tasks to specialized sub-agents, monitors progress.",
      "prompt": "You are `harness`. Your complete role is defined in `.agents/subagents/harness/SUBAGENT.md` — read that file FIRST and follow it strictly."
    },
    "spec-author": {
      "mode": "subagent",
      "description": "Creates specs/<feature>/{requirements,design,tasks}.md in strict EARS. Never writes production code. Stops at status=spec_ready and waits for human approval.",
      "prompt": "You are `spec-author`. Your complete role is defined in `.agents/subagents/spec-author/SUBAGENT.md` — read that file FIRST and follow it strictly.",
      "permission": {
        "edit": {
          "specs/**": "allow",
          "progress/**": "allow",
          "feature_list.json": "allow",
          "*": "deny"
        }
      }
    },
    "implementer": {
      "mode": "subagent",
      "description": "Executes tasks.md sequentially on the feature with status=in_progress.",
      "prompt": "You are `implementer`. Your complete role is defined in `.agents/subagents/implementer/SUBAGENT.md` — read that file FIRST and follow it strictly.",
      "permission": {
        "edit": {
          "specs/**": "deny",
          "feature_list.json": "ask",
          "*": "allow"
        }
      }
    },
    "reviewer": {
      "mode": "subagent",
      "description": "Verifies R<n>↔test traceability. Runs ./check.sh. Marks the feature as done only if all checks pass.",
      "prompt": "You are `reviewer`. Your complete role is defined in `.agents/subagents/reviewer/SUBAGENT.md` — read that file FIRST and follow it strictly.",
      "permission": {
        "edit": {
          "progress/**": "allow",
          "feature_list.json": "allow",
          "*": "deny"
        }
      }
    }
  },
  "command": {
    "init":      { "description": "Set up Harness SDD for this project (agent-driven scaffold lifecycle)", "template": "Read `.agents/commands/init.md` and execute the workflow described there." },
    "status":    { "description": "Show project state (active feature, specs pending, last progress entries)", "template": "Read `.agents/commands/status.md` and execute the workflow described there." },
    "spec":      { "description": "Create spec (requirements/design/tasks) for a pending feature", "template": "Read `.agents/commands/spec.md` and execute the workflow described there." },
    "approve":   { "description": "Approve a spec_ready feature and flip it to in_progress",       "template": "Read `.agents/commands/approve.md` and execute the workflow described there." },
    "implement": { "description": "Run the implementer on the current in_progress feature",       "template": "Read `.agents/commands/implement.md` and execute the workflow described there." },
    "done":      { "description": "Run the reviewer, verify traceability, mark feature as done",   "template": "Read `.agents/commands/done.md` and execute the workflow described there." },
    "check":     { "description": "Shortcut to ./check.sh",                                       "template": "Read `.agents/commands/check.md` and execute the workflow described there." }
  }
}
